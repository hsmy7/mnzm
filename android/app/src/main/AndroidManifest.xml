<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Android 11+ 包可见性配置（Dirichlet Ad SDK 需要） -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
        </intent>
        <package android:name="com.tencent.mm" />
    </queries>

    <!-- 基本网络权限 - 用于云存档和网络功能 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Dirichlet Ad SDK 建议权限 - 获取更精准的广告推送数据 -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <!-- targetSdk 31 及以上建议添加 -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- 获取更好的广告体验，建议加上位置权限 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- 提高广告转化率 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- CPU 休眠防护：游戏循环运行时保持 CPU 活跃，防止华为等 OEM 挂起线程 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 前台服务：游戏循环需要前台优先级，避免被 OEM 电源管理冻结游戏时间 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- 精确闹钟：用于 AlarmWatchdogReceiver 周期性唤醒检查游戏循环状态 -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- 存储权限 - 用于存档功能 -->
    <!-- 注意：在 Android 10 (API 29) 及以上版本，应用只能访问自己的私有目录 -->
    <!-- maxSdkVersion="28" 表示这些权限仅在 Android 9 及以下版本请求 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!--
    权限使用说明：
    1. INTERNET/ACCESS_NETWORK_STATE/ACCESS_WIFI_STATE：用于云存档同步、数据备份等网络功能
    2. WRITE_EXTERNAL_STORAGE/READ_EXTERNAL_STORAGE：用于本地存档文件的读写（仅 API 28 及以下）

    运行时权限检查：
    - 对于 API 23-28：需要在运行时请求存储权限（已在相关 Activity 中处理）
    - 对于 API 29+：使用分区存储，无需请求这些权限

    如果将来需要以下功能，请添加对应权限：
    - 前台服务：<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    - 保持设备唤醒：<uses-permission android:name="android.permission.WAKE_LOCK" />
    - 震动反馈：<uses-permission android:name="android.permission.VIBRATE" />
    - 开机自启：<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    -->

    <!-- 设备特性声明 - 非必需 -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.hardware.screen.landscape" android:required="true" />

    <application
        android:name=".XianxiaApplication"
        android:allowBackup="true"
        android:appCategory="game"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.XianxiaSect"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true"
        android:largeHeap="true"
        android:extractNativeLibs="true"
        android:hardwareAccelerated="true">

        <!-- Game Mode API (Android 12+) -->
        <meta-data
            android:name="com.android.app.gamemode.performance.enabled"
            android:value="true" />
        <meta-data
            android:name="com.android.app.gamemode.battery.enabled"
            android:value="false" />

        <!-- Google Play Games Services 预留（v4.0.00 尚未启用）
             启用步骤：
             1. 在 Firebase Console 创建项目并启用 Play Games Services
             2. 在 Google Play Console 关联游戏并获取 OAuth Client ID
             3. 在 android/ 下添加 google-services.json
             4. 在 gradle/libs.versions.toml 和 app/build.gradle 中取消 Firebase 依赖注释
             5. 取消以下注释并填入实际值
        <meta-data
            android:name="com.google.android.gms.games.APP_ID"
            android:value="@string/game_services_app_id" />
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />
        <meta-data
            android:name="com.google.android.gms.appstate.APP_ID"
            android:value="@string/game_services_app_id" />
        -->

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.XianxiaSect.Splash"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden"
            android:screenOrientation="landscape"
            android:windowSoftInputMode="adjustResize"
            tools:ignore="LockedOrientationActivity,DiscouragedApi">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.game.GameActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden"
            android:screenOrientation="landscape"
            android:windowSoftInputMode="adjustResize"
            tools:ignore="LockedOrientationActivity,DiscouragedApi" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Dirichlet Ad SDK FileProvider（使用 AndroidX FileProvider 替代 SDK 内置的 Support 版本） -->
        <provider
            android:authorities="${applicationId}.com.tds.ad.fileprovider"
            android:name="androidx.core.content.FileProvider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/tapad_ad_file_path"/>
        </provider>

        <!-- 禁用 TapTap SDK 的 ContentProvider 自动初始化，确保在用户同意隐私政策后才初始化 SDK -->
        <provider
            android:name="com.taptap.sdk.kit.internal.TapTapKitInitProvider"
            android:authorities="${applicationId}.TapTapKitInitProvider"
            android:exported="false"
            tools:node="remove"
            tools:ignore="MissingClass" />
        <provider
            android:name="com.taptap.sdk.themis.lite.ThemisProvider"
            android:authorities="${applicationId}.themisLite"
            android:exported="false"
            tools:node="remove"
            tools:ignore="MissingClass" />
        <!-- 禁用 Dirichlet Ad SDK 的 ContentProvider 自动初始化，避免在用户同意隐私政策前收集传感器等信息 -->
        <provider
            android:name="com.tapsdk.tapad.TapAdInitProvider"
            android:authorities="${applicationId}.TapAdInitProvider"
            android:exported="false"
            tools:node="remove"
            tools:ignore="MissingClass" />

        <!-- 游戏前台服务：保持游戏循环在前台优先级运行，避免被 OEM 电源管理冻结 -->
        <service
            android:name=".core.util.GameForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Game loop needs foreground priority to avoid OEM power management freezing game time" />
        </service>

        <!-- 闹钟看门狗接收器：周期性唤醒检查游戏循环状态 -->
        <receiver
            android:name=".core.util.AlarmWatchdogReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.xianxia.sect.action.ALARM_WATCHDOG" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
